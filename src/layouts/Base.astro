---
const { title = 'অলীকবচন Ledger', description = 'Verified findings — team Make America Great Again' } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Public site, unlisted. Block all crawlers/indexers (verified in <head>). -->
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
    <meta name="googlebot" content="noindex, nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/json" href={`${import.meta.env.BASE_URL}/findings.json`} title="Findings (structured data for AI agents)" />
    <link rel="alternate" type="text/plain" href={`${import.meta.env.BASE_URL}/llms.txt`} title="llms.txt (plain-text dump for AI agents)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
