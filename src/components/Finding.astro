---
import team from '../data/team.json';
import glossary from '../data/glossary.json';
const { f, i = 0 } = Astro.props;
const members = team.members;
const initials = (key) => (members[key]?.name || key).replace('@','').slice(0,2).toUpperCase();
const handle = (key) => members[key]?.handle || `@${key}`;
const mentionsStr = (f.mentions || []).map(handle).join(', ');

// Wrap known glossary terms with a hover-definition <abbr>. Longest terms first
// so "binary-F1" wins over "F1". Case-insensitive, first hit per term per text.
const terms = Object.keys(glossary).sort((a, b) => b.length - a.length);
const escapeRe = (s) => s.replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&');
const escapeAttr = (s) => s.replace(/"/g, '&quot;');
function gloss(text) {
  if (!text) return '';
  let out = text;
  const used = new Set();
  for (const t of terms) {
    if (used.has(t)) continue;
    const re = new RegExp('(?<![\\w-])(' + escapeRe(t) + ')(?![\\w-])', 'i');
    out = out.replace(re, (m) => {
      used.add(t);
      return '<button type="button" class="gloss" data-def="' + escapeAttr(glossary[t]) + '" aria-label="' + escapeAttr(t + ': ' + glossary[t]) + '">' + m + '</button>';
    });
  }
  return out;
}
---
<details class="finding" data-verdict={f.verdict} data-cat={f.category} id={f.id} style={`--i:${i}`}>
  <summary>
    <span class="s-who" title={`found by ${handle(f.author)}`}>
      <span class="s-dot">{initials(f.author)}</span>
      <span class="s-handle">{handle(f.author)}</span>
    </span>
    <span class="s-glance" set:html={gloss(f.glance || f.summary)}></span>
    <span class="s-tags">
      {f.hot && <span class="badge hot">🔥 hot read</span>}
      <span class={`badge ${f.verdict}`}>{f.verdict}</span>
      {f.redact && <span class="badge redact">redact</span>}
      <span class="f-id">{f.id}</span>
      <span class="f-ver">v{f.version}</span>
    </span>
  </summary>

  <div class="f-inner">
    <h3 class="f-title" set:html={gloss(f.title)}></h3>
    <div class="f-meta">
      <span class="f-cat">{f.category}</span>
      <span class={`badge ${f.verdict}`}>{f.verdict}</span>
      <span class="badge conf">{f.confidence}</span>
      {f.critical && <span class="badge conf">critical</span>}
    </div>

    {f.why && (
      <p class="why"><span class="lbl">Why it matters</span><span set:html={gloss(f.why)}></span></p>
    )}

    <div class="explain" set:html={gloss(f.body)}></div>

    {f.keyEvidence && (
      <div class="keyev"><span class="lbl">How we know</span><span set:html={gloss(f.keyEvidence)}></span></div>
    )}

    {f.action && (
      <div class="action"><span class="lbl">Do this</span><span set:html={gloss(f.action)}></span></div>
    )}

    {f.caveat && (
      <p class="caveat"><span set:html={gloss(f.caveat)}></span></p>
    )}

    <details class="tech">
      <summary>Full detail &amp; sources</summary>
      <div class="tech-inner">
        {f.evidence?.map((e) => (
          <div class="evidence">
            <blockquote>{e.quote}</blockquote>
            <div class="cite">— <b>{e.source}</b> · {e.date}</div>
          </div>
        ))}
        <div class="attrib">
          <span class="who"><span class="dot">{initials(f.author)}</span><span class="lbl">found</span><span class="h">{handle(f.author)}</span></span>
          <span class="who"><span class="dot v">{initials(f.verifier)}</span><span class="lbl">verified</span><span class="h">{handle(f.verifier)}</span></span>
          {f.mentions?.length > 0 && (
            <span class="who mentions"><span class="lbl">cc</span><span class="h">{mentionsStr}</span></span>
          )}
          <span class="who" style="margin-left:auto"><span class="lbl">updated</span><span class="h">{f.updated}</span></span>
        </div>
        {f.changelog?.length > 0 && (
          <div class="cl">
            <span class="lbl">Changelog</span>
            <ol>
              {[...f.changelog].reverse().map((c)=>(
                <li><span class="v">v{c.version}</span><span class="d">{c.date}</span><span class="note">{c.note}</span></li>
              ))}
            </ol>
          </div>
        )}
      </div>
    </details>
  </div>
</details>
